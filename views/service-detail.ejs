<div class="service-detail">
    <a href="/services" class="btn">Back to services</a>

    <h1><%= service.name %></h1>

    <div class="detail-content">
        <p><strong>Description:</strong> <%= service.description %></p>
        <p><strong>Duration:</strong> <%= service.duration_minutes %> minutes</p>
        <p><strong>Price:</strong> $<%= parseFloat(service.price).toFixed(2) %></p>
    </div>

    <a href="/bookings/new?service_id=<%= service.id %>" class="btn">Book This Service</a>
</div>