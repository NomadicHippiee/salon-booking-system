<div class="form-container">
    <h1><%= service ? 'Edit Service' : 'Create New Service' %></h1>

    <% if (errors.length > 0) { %>
        <div class="alert alert-error">
            <ul>
                <% errors.forEach(error => { %>
                    <li><%= error.msg %></li>
                <% }); %>
            </ul>
        </div>

    <% } %>

    <form method="POST" action="<%= service ? '/services/' + service.id : '/services' %>" class="form">
        <div class="form-group">
            <label for="name">Service Name *</label>
            <input type="text" id="name" name="name" value="<%- service ? service.name : '' %>" required>
        </div>
        <div class="form-group">
            <label for="description">Description *</label>
          <textarea name="description" id="description" rows="4" required><%= service ? service.description : '' %></textarea>
        </div>
        <div class="form-group">
            <label for="duration_minutes">Duration in Minutes *</label>
            <input type="number" id="duration_minutes" name="duration_minutes" min="1" value="<%= service ? service.duration_minutes : '' %>" required>
        </div>
        <div class="form-group">
                <label for="price">Price *</label>
                <input type="number" id="price" name="price" step="0.01" min="0" value="<%= service ? service.price : '' %>" required>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn"><%= service ? 'Update Service' : 'Create Service' %></button>
            <a href="/services" class="btn">Cancel</a>
            
        </div>
    </form>
</div>